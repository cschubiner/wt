#!/usr/bin/env bash
# wt-zellij — Zellij backend for persistent worktree sessions
# Usage: wt-zellij [here|codex|claude|pick|pickdir|cd|revive|ls|kill]
set -euo pipefail

# ---- ANSI colors ----
C_RESET=$'\033[0m'
C_GREEN=$'\033[1;32m'
C_YELLOW=$'\033[1;33m'
C_CYAN=$'\033[1;36m'
C_GRAY=$'\033[0;90m'

# Registry of known wt directories so we can map session name <-> dir.
WT_REGISTRY_FILE="${WT_REGISTRY_FILE:-$HOME/.wt_registry}"
WT_ZELLIJ_STATE_DIR="${WT_ZELLIJ_STATE_DIR:-$HOME/.wt_zellij}"
WT_ZELLIJ_META_DIR="$WT_ZELLIJ_STATE_DIR/sessions"
WT_ZELLIJ_AGE_CACHE_FILE="${WT_ZELLIJ_AGE_CACHE_FILE:-$WT_ZELLIJ_STATE_DIR/age_cache.tsv}"
WT_ZELLIJ_AGE_CACHE_LOCK_FILE="$WT_ZELLIJ_STATE_DIR/age_cache.lock"
WT_ZELLIJ_DISCOVERY_CACHE_FILE="${WT_ZELLIJ_DISCOVERY_CACHE_FILE:-$WT_ZELLIJ_STATE_DIR/discovery_cache.tsv}"
WT_ZELLIJ_DISCOVERY_CACHE_LOCK_FILE="$WT_ZELLIJ_STATE_DIR/discovery_cache.lock"
WT_ZELLIJ_DEBUG_LOG_FILE="${WT_ZELLIJ_DEBUG_LOG_FILE:-$WT_ZELLIJ_STATE_DIR/debug.log}"
WT_ZELLIJ_INSIDE_CACHE_SET=0
WT_ZELLIJ_INSIDE_CACHE=0

debug_log() {
  [[ "${WT_DEBUG:-0}" == "1" ]] || return 0
  mkdir -p "$WT_ZELLIJ_STATE_DIR"
  printf "%s\tpid=%s\t%s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$$" "$*" >> "$WT_ZELLIJ_DEBUG_LOG_FILE"
}

ensure_state_dirs() {
  mkdir -p "$WT_ZELLIJ_META_DIR"
}

session_meta_path() {
  local sess="$1"
  printf "%s/%s.meta" "$WT_ZELLIJ_META_DIR" "$sess"
}

session_meta_get_field() {
  local sess="$1" field="$2" p
  p="$(session_meta_path "$sess")"
  [[ -f "$p" ]] || return 1
  awk -F= -v key="$field" '$1 == key {sub(/^[^=]*=/, "", $0); print; exit}' "$p"
}

session_meta_get_last_activity() {
  local sess="$1" p
  p="$(session_meta_path "$sess")"
  [[ -f "$p" ]] || return 1
  awk -F= '
    $1 == "last_active_ts" {ts = $2}
    $1 == "last_active_source" {src = $2}
    END {
      if (ts != "") {
        print ts "|" src
      }
    }
  ' "$p"
}

session_meta_set_field() {
  local sess="$1" field="$2" value="$3" p tmp
  ensure_state_dirs
  p="$(session_meta_path "$sess")"
  tmp="$(mktemp)"
  if [[ -f "$p" ]]; then
    awk -F= -v key="$field" '$1 != key {print}' "$p" > "$tmp" || true
  fi
  printf "%s=%s\n" "$field" "$value" >> "$tmp"
  mv "$tmp" "$p"
}

session_meta_touch() {
  local sess="$1"
  session_meta_mark_activity "$sess" "manual"
}

session_meta_mark_activity() {
  local sess="$1" source="${2:-manual}" now
  now="$(date +%s)"
  session_meta_set_field "$sess" "last_active_ts" "$now"
  session_meta_set_field "$sess" "last_active_source" "$source"
}

session_meta_set_dir() {
  local sess="$1" dir="$2"
  [[ -n "$dir" && -d "$dir" ]] || return 0
  session_meta_set_field "$sess" "dir" "$(canonpath "$dir")"
}

session_meta_get_dir() {
  local sess="$1" d
  d="$(session_meta_get_field "$sess" "dir" 2>/dev/null || true)"
  [[ -n "$d" && -d "$d" ]] || return 1
  printf "%s" "$d"
}

session_meta_remove() {
  local sess="$1"
  rm -f "$(session_meta_path "$sess")" >/dev/null 2>&1 || true
}

refresh_discovery_cache() {
  local tmp
  ensure_state_dirs
  tmp="$(mktemp)"
  discover_worktree_dirs > "$tmp" 2>/dev/null || true
  mv "$tmp" "$WT_ZELLIJ_DISCOVERY_CACHE_FILE"
}

maybe_refresh_discovery_cache_async() {
  local now cache_mtime ttl
  ttl="${WT_ZELLIJ_DISCOVERY_CACHE_TTL:-15}"
  now="$(date +%s)"
  cache_mtime="$(mtime_epoch "$WT_ZELLIJ_DISCOVERY_CACHE_FILE" 2>/dev/null || echo 0)"
  if [[ "$cache_mtime" =~ ^[0-9]+$ ]] && (( now - cache_mtime < ttl )); then
    return 0
  fi

  ensure_state_dirs
  if ( set -o noclobber; : > "$WT_ZELLIJ_DISCOVERY_CACHE_LOCK_FILE" ) 2>/dev/null; then
    (
      "$0" _refresh_discovery_cache >/dev/null 2>&1 || true
      rm -f "$WT_ZELLIJ_DISCOVERY_CACHE_LOCK_FILE" >/dev/null 2>&1 || true
    ) &
  fi
}

discovered_dirs_cached() {
  ensure_state_dirs
  if [[ ! -s "$WT_ZELLIJ_DISCOVERY_CACHE_FILE" ]]; then
    refresh_discovery_cache
  else
    maybe_refresh_discovery_cache_async
  fi
  cat "$WT_ZELLIJ_DISCOVERY_CACHE_FILE"
}

canonpath() {
  if command -v realpath >/dev/null 2>&1; then
    realpath "$1"
  else
    python3 - "$1" <<'PY'
import os, sys; print(os.path.realpath(sys.argv[1]))
PY
  fi
}

hash6() {
  local s="$1"
  if command -v sha1sum >/dev/null 2>&1; then
    printf "%s" "$s" | sha1sum | awk '{print substr($1,1,6)}'
  elif command -v shasum >/dev/null 2>&1; then
    printf "%s" "$s" | shasum | awk '{print substr($1,1,6)}'
  else
    python3 - "$s" <<'PY'
import hashlib, sys; print(hashlib.sha1(sys.argv[1].encode()).hexdigest()[:6])
PY
  fi
}

sess_for_dir() {
  local dir="$1"
  local base
  base="$(basename "$dir" | tr -cs 'A-Za-z0-9' '_' | sed 's/_*$//' | cut -c1-24)"
  local h
  h="$(hash6 "$dir")"
  echo "wt_${base}_${h}"
}

inside_zellij() {
  if [[ "$WT_ZELLIJ_INSIDE_CACHE_SET" == "1" ]]; then
    [[ "$WT_ZELLIJ_INSIDE_CACHE" == "1" ]]
    return
  fi

  if [[ -n "${ZELLIJ:-}" || -n "${ZELLIJ_SESSION_NAME:-}" ]]; then
    WT_ZELLIJ_INSIDE_CACHE_SET=1
    WT_ZELLIJ_INSIDE_CACHE=1
    return 0
  fi

  WT_ZELLIJ_INSIDE_CACHE_SET=1
  WT_ZELLIJ_INSIDE_CACHE=0
  return 1
}

short_path() {
  printf "%s" "${1/#$HOME/~}"
}

collapse_dir_for_display() {
  local dir="$1"
  case "$dir" in
    \~/Downloads/worktrees/*)
      printf ".../%s" "${dir#\~/Downloads/worktrees/}"
      ;;
    \~/.codex/worktrees/*)
      printf ".../%s" "${dir#\~/.codex/worktrees/}"
      ;;
    \~/.openclaw/workspace/*)
      printf ".../%s" "${dir#\~/.openclaw/workspace/}"
      ;;
    *)
      printf "%s" "$dir"
      ;;
  esac
}

registry_add_dir() {
  local dir="${1:-}"
  [[ -n "$dir" && -d "$dir" ]] || return 0
  dir="$(canonpath "$dir")"
  mkdir -p "$(dirname "$WT_REGISTRY_FILE")"
  touch "$WT_REGISTRY_FILE"
  grep -Fxq "$dir" "$WT_REGISTRY_FILE" 2>/dev/null || printf "%s\n" "$dir" >> "$WT_REGISTRY_FILE"
}

registry_has_dirs() {
  local d
  [[ -f "$WT_REGISTRY_FILE" ]] || return 1
  while IFS= read -r d; do
    [[ -d "$d" ]] && return 0
  done < "$WT_REGISTRY_FILE"
  return 1
}

registry_dirs() {
  local d
  [[ -f "$WT_REGISTRY_FILE" ]] || return 0
  while IFS= read -r d; do
    [[ -d "$d" ]] || continue
    printf "%s\n" "$d"
  done < "$WT_REGISTRY_FILE" | awk 'NF && !seen[$0]++'
}

discover_roots() {
  local -a roots
  local root
  if [[ -n "${WT_DISCOVER_ROOTS:-}" ]]; then
    IFS=':' read -r -a roots <<<"${WT_DISCOVER_ROOTS}"
    for root in "${roots[@]}"; do
      [[ -n "$root" ]] && printf "%s\n" "$root"
    done
    return 0
  fi

  printf "%s\n" \
    "$HOME/Downloads/worktrees" \
    "$HOME/.codex/worktrees" \
    "$HOME/.openclaw/workspace" \
    "$PWD"
}

discover_dirs_under_root_fast() {
  local root="$1"
  local d1 d2 gitpath dir
  local found=0
  local maxdepth
  maxdepth="${WT_DISCOVER_FALLBACK_MAXDEPTH:-3}"

  [[ -d "$root" ]] || return 0

  # Common layouts:
  # - <root>/<repo>/.git
  # - <root>/<group>/<repo>/.git
  if [[ -e "$root/.git" ]]; then
    canonpath "$root"
    found=1
  fi

  for d1 in "$root"/*; do
    [[ -d "$d1" ]] || continue
    if [[ -e "$d1/.git" ]]; then
      canonpath "$d1"
      found=1
      continue
    fi
    for d2 in "$d1"/*; do
      [[ -d "$d2" ]] || continue
      [[ -e "$d2/.git" ]] || continue
      canonpath "$d2"
      found=1
    done
  done

  # Fallback for unexpected/custom layouts.
  if (( found == 0 )); then
    while IFS= read -r gitpath; do
      dir="$(dirname "$gitpath")"
      [[ -d "$dir" ]] || continue
      canonpath "$dir"
    done < <(find "$root" -mindepth 1 -maxdepth "$maxdepth" \( -type f -o -type d \) -name .git 2>/dev/null)
  fi
}

discover_worktree_dirs() {
  local root expanded
  while IFS= read -r root; do
    [[ -n "$root" ]] || continue
    if [[ "$root" == "~"* ]]; then
      expanded="${HOME}${root:1}"
    else
      expanded="$root"
    fi
    [[ -d "$expanded" ]] || continue
    discover_dirs_under_root_fast "$expanded"
  done < <(discover_roots) | awk 'NF && !seen[$0]++'
}

require_zellij() {
  if ! command -v zellij >/dev/null 2>&1; then
    echo "zellij is required for WT_BACKEND=zellij. Install with: brew install zellij" >&2
    exit 1
  fi
}

run_with_timeout() {
  local timeout_sec="$1"
  shift
  perl -e '
    my $sec = shift @ARGV;
    my $pid = fork();
    die "fork failed\n" unless defined $pid;
    if ($pid == 0) {
      exec @ARGV;
      exit 127;
    }
    $SIG{ALRM} = sub {
      kill 9, $pid;
      waitpid($pid, 0);
      exit 124;
    };
    alarm($sec);
    waitpid($pid, 0);
    alarm(0);
    my $status = $? >> 8;
    exit $status;
  ' "$timeout_sec" "$@"
}

mtime_epoch() {
  local path="$1"
  [[ -e "$path" ]] || return 1
  stat -f %m "$path" 2>/dev/null || stat -c %Y "$path" 2>/dev/null
}

dir_activity_ts() {
  local dir="$1" fallback="$2" out_var="${3:-}"
  local result_ts="" git_dir=""

  if [[ -n "$dir" && -d "$dir" ]]; then
    if [[ -f "$dir/.git/HEAD" ]]; then
      result_ts="$(mtime_epoch "$dir/.git/HEAD" 2>/dev/null || true)"
    elif [[ -f "$dir/.git" ]]; then
      git_dir="$(sed -n 's/^gitdir: //p' "$dir/.git" 2>/dev/null | head -n1)"
      if [[ -n "$git_dir" && "$git_dir" != /* ]]; then
        git_dir="$dir/$git_dir"
      fi
      if [[ -n "$git_dir" ]]; then
        result_ts="$(mtime_epoch "$git_dir/HEAD" 2>/dev/null || true)"
      fi
    fi

    if ! [[ "$result_ts" =~ ^[0-9]+$ ]]; then
      result_ts="$(mtime_epoch "$dir" 2>/dev/null || true)"
    fi
  fi

  if ! [[ "$result_ts" =~ ^[0-9]+$ ]]; then
    if [[ "$fallback" =~ ^[0-9]+$ ]]; then
      result_ts="$fallback"
    else
      result_ts="$(date +%s)"
    fi
  fi

  if [[ -n "$out_var" ]]; then
    if [[ "$out_var" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
      eval "$out_var=\"\$result_ts\""
    else
      return 1
    fi
  else
    printf "%s" "$result_ts"
  fi
}

refresh_age_cache() {
  local tmp now dir ts
  ensure_state_dirs
  tmp="$(mktemp)"
  now="$(date +%s)"
  while IFS= read -r dir; do
    [[ -n "$dir" && -d "$dir" ]] || continue
    dir_activity_ts "$dir" "$now" ts
    printf "%s\t%s\t%s\n" "$dir" "$ts" "$now" >> "$tmp"
  done < <(
    {
      registry_dirs
      discovered_dirs_cached
    } | awk 'NF && !seen[$0]++'
  )
  mv "$tmp" "$WT_ZELLIJ_AGE_CACHE_FILE"
}

maybe_refresh_age_cache_async() {
  local now cache_mtime ttl
  ttl="${WT_ZELLIJ_AGE_CACHE_TTL:-120}"
  now="$(date +%s)"
  cache_mtime="$(mtime_epoch "$WT_ZELLIJ_AGE_CACHE_FILE" 2>/dev/null || echo 0)"
  if [[ "$cache_mtime" =~ ^[0-9]+$ ]] && (( now - cache_mtime < ttl )); then
    return 0
  fi

  ensure_state_dirs
  if ( set -o noclobber; : > "$WT_ZELLIJ_AGE_CACHE_LOCK_FILE" ) 2>/dev/null; then
    (
      "$0" _refresh_age_cache >/dev/null 2>&1 || true
      rm -f "$WT_ZELLIJ_AGE_CACHE_LOCK_FILE" >/dev/null 2>&1 || true
    ) &
  fi
}

session_exists() {
  local sess="$1"
  local out
  out="$(run_with_timeout 3 zellij --session "$sess" action query-tab-names 2>&1 || true)"
  [[ -n "$out" ]] || return 1
  [[ "$out" == *"There is no active session"* ]] && return 1
  [[ "$out" == *"not found"* ]] && return 1
  [[ "$out" == *"Tab #"* ]] && return 0
  return 0
}

ensure_session() {
  local sess="$1" dir="$2"
  local attempt
  registry_add_dir "$dir"
  session_meta_set_dir "$sess" "$dir"
  if ! session_exists "$sess"; then
    # Keep stdio attached so zellij initializes input handling with a real tty.
    (cd "$dir" && run_with_timeout 8 zellij attach -c -b "$sess") || true
  fi
  for attempt in 1 2 3; do
    session_exists "$sess" && return 0
    sleep 0.5
  done
  echo "Failed to ensure zellij session '$sess' (timed out)." >&2
  return 1
}

dir_for_session() {
  local sess="$1" d h
  d="$(session_meta_get_dir "$sess" 2>/dev/null || true)"
  if [[ -n "$d" ]]; then
    printf "%s" "$d"
    return 0
  fi

  # Exact match via registry.
  while IFS= read -r d; do
    [[ -n "$d" ]] || continue
    if [[ "$(sess_for_dir "$d")" == "$sess" ]]; then
      session_meta_set_dir "$sess" "$d"
      printf "%s" "$d"
      return 0
    fi
  done < <(registry_dirs)

  # Hash fallback for cases where the session base segment was truncated differently.
  h="${sess##*_}"
  if [[ "$h" =~ ^[0-9a-fA-F]{6}$ ]]; then
    while IFS= read -r d; do
      [[ -n "$d" ]] || continue
      if [[ "$(hash6 "$d")" == "$h" ]]; then
        session_meta_set_dir "$sess" "$d"
        printf "%s" "$d"
        return 0
      fi
    done < <(registry_dirs)

    if [[ "${WT_ZELLIJ_DIR_DISCOVERY_FALLBACK:-0}" == "1" ]]; then
      # Last resort: one discovery scan cached for this invocation.
      while IFS= read -r d; do
        [[ -n "$d" ]] || continue
        if [[ "$(hash6 "$d")" == "$h" ]]; then
          registry_add_dir "$d"
          session_meta_set_dir "$sess" "$d"
          printf "%s" "$d"
          return 0
        fi
      done < <(discovered_dirs_cached)
    fi
  fi

  return 1
}

find_active_session_for_dir() {
  local target="$1"
  local sess mapped mapped_canon
  target="$(canonpath "$target")"

  while IFS='|' read -r sess _; do
    [[ -n "$sess" ]] || continue
    mapped="$(dir_for_session "$sess" 2>/dev/null || true)"
    [[ -n "$mapped" && -d "$mapped" ]] || continue
    mapped_canon="$(canonpath "$mapped" 2>/dev/null || true)"
    [[ "$mapped_canon" == "$target" ]] && { printf "%s" "$sess"; return 0; }
  done < <(list_sessions_raw)

  return 1
}

session_tab_names() {
  local sess="$1"
  run_with_timeout 4 zellij --session "$sess" action query-tab-names 2>/dev/null || true
}

session_has_tab() {
  local sess="$1" tab="$2"
  session_tab_names "$sess" | grep -Fxq "$tab"
}

session_agents() {
  local sess="$1"
  local tabs
  tabs="$(session_tab_names "$sess")"
  local has_codex=0 has_claude=0
  printf "%s\n" "$tabs" | grep -Fxq "codex" && has_codex=1
  printf "%s\n" "$tabs" | grep -Fxq "claude" && has_claude=1

  if (( has_codex == 1 && has_claude == 1 )); then
    printf "codex,claude"
  elif (( has_codex == 1 )); then
    printf "codex"
  elif (( has_claude == 1 )); then
    printf "claude"
  else
    printf "(none)"
  fi
}

color_agents() {
  local agents="$1"
  case "$agents" in
    *codex*,*claude*|*claude*,*codex*)
      printf "${C_GREEN}%s${C_RESET}" "$agents" ;;
    *codex*)
      printf "${C_YELLOW}%s${C_RESET}" "$agents" ;;
    *claude*)
      printf "${C_CYAN}%s${C_RESET}" "$agents" ;;
    *)
      printf "${C_GRAY}%s${C_RESET}" "$agents" ;;
  esac
}

session_client_count() {
  local sess="$1"
  local out
  out="$(run_with_timeout 4 zellij --session "$sess" action list-clients 2>/dev/null || true)"
  printf "%s\n" "$out" | tail -n +2 | sed '/^[[:space:]]*$/d' | wc -l | tr -d ' '
}

age_phrase_to_seconds() {
  local phrase="$1"
  local token num unit total=0

  # phrase examples: "7s", "1m 7s", "3h 2m", "2d"
  for token in $phrase; do
    if [[ "$token" =~ ^([0-9]+)([A-Za-z]+)$ ]]; then
      num="${BASH_REMATCH[1]}"
      unit="$(printf "%s" "${BASH_REMATCH[2]}" | tr '[:upper:]' '[:lower:]')"
      case "$unit" in
        s|sec|secs|second|seconds) total=$((total + num)) ;;
        m|min|mins|minute|minutes) total=$((total + num * 60)) ;;
        h|hr|hrs|hour|hours) total=$((total + num * 3600)) ;;
        d|day|days) total=$((total + num * 86400)) ;;
        w|wk|wks|week|weeks) total=$((total + num * 604800)) ;;
        mo|mon|month|months) total=$((total + num * 2592000)) ;;
        y|yr|yrs|year|years) total=$((total + num * 31536000)) ;;
      esac
    fi
  done
  printf "%s" "$total"
}

relative_time() {
  local ts="$1"
  local now="${2:-}"
  local delta
  [[ -z "$now" ]] && now="$(date +%s)"
  delta=$(( now - ts ))
  (( delta < 0 )) && delta=0
  if   (( delta < 60   )); then printf "%ds ago" "$delta"
  elif (( delta < 3600 )); then printf "%dm ago" "$(( delta / 60 ))"
  elif (( delta < 86400)); then printf "%dh ago" "$(( delta / 3600 ))"
  else                          printf "%dd ago" "$(( delta / 86400 ))"
  fi
}

list_sessions_raw() {
  local now line sess phrase age_sec created_ts effective_ts meta_last meta_source meta_pair
  now="$(date +%s)"

  (run_with_timeout 5 zellij list-sessions -n -r 2>/dev/null || true) \
    | while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        [[ "$line" == "No active zellij sessions found."* ]] && continue

        sess="$(printf "%s" "$line" | awk '{print $1}')"
        [[ "$sess" =~ ^wt_ ]] || continue

        phrase=""
        if [[ "$line" =~ \[Created[[:space:]]+(.+)[[:space:]]+ago\] ]]; then
          phrase="${BASH_REMATCH[1]}"
        fi

        if [[ -n "$phrase" ]]; then
          age_sec="$(age_phrase_to_seconds "$phrase")"
          created_ts="$(( now - age_sec ))"
        else
          created_ts="$now"
        fi

        effective_ts="$created_ts"
        meta_last=""
        meta_source=""
        meta_pair="$(session_meta_get_last_activity "$sess" 2>/dev/null || true)"
        if [[ -n "$meta_pair" ]]; then
          meta_last="${meta_pair%%|*}"
          meta_source="${meta_pair#*|}"
        fi
        if [[ "$meta_last" =~ ^[0-9]+$ ]] && [[ -n "$meta_source" ]] && (( meta_last > effective_ts )); then
          effective_ts="$meta_last"
        fi

        printf "%s|%s|%s\n" "$sess" "$effective_ts" "$created_ts"
      done \
    | sort -t'|' -k2,2nr
}

list_known_sessions_raw() {
  local now_ts dir ts
  now_ts="$(date +%s)"
  while IFS= read -r dir; do
    [[ -n "$dir" ]] || continue
    ts="$now_ts"
    printf "%s|%s|%s|0|%s\n" "$dir" "$ts" "$ts" "$dir"
  done < <(
    {
      registry_dirs
      discovered_dirs_cached
    } | awk 'NF && !seen[$0]++'
  ) | sort -t'|' -k2,2nr
}

list_known_sessions_with_cached_age() {
  local tmp_known
  tmp_known="$(mktemp)"
  list_known_sessions_raw > "$tmp_known"
  if [[ -s "$WT_ZELLIJ_AGE_CACHE_FILE" ]]; then
    awk -F'\t' '
      FNR == NR {
        if (NF >= 2 && $2 ~ /^[0-9]+$/) {
          age_ts[$1] = $2
        }
        next
      }
      {
        n = split($0, a, "|")
        dir = (n >= 5 ? a[5] : "")
        if (dir in age_ts) {
          a[2] = age_ts[dir]
        }
        print a[1] "|" a[2] "|" a[3] "|" a[4] "|" a[5]
      }
    ' "$WT_ZELLIJ_AGE_CACHE_FILE" "$tmp_known"
  else
    cat "$tmp_known"
  fi
  rm -f "$tmp_known"
}

list_attached_sessions() {
  local line cmd sess
  pgrep -fl 'zellij attach|/zellij attach' 2>/dev/null \
    | while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        cmd="${line#* }"
        sess="$(
          printf '%s\n' "$cmd" | perl -ne '
            if (/\battach\b(.*)$/) {
              $rest = $1;
              @tok = split(/\s+/, $rest);
              for ($i = 0; $i < scalar(@tok); $i++) {
                $t = $tok[$i];
                next if $t eq "";
                if ($t =~ /^(--index|-i)$/) { $i++; next; }
                next if $t =~ /^-/;
                print "$t\n";
                exit;
              }
            }
          '
        )"
        [[ -n "$sess" ]] && printf "%s\n" "$sess"
      done \
    | awk 'NF && !seen[$0]++'
}

list_sessions_combined_raw() {
  local tmp_active tmp_known tmp_active_dirs
  local sess effective_ts created_ts dir
  local known_sess known_effective known_created known_is_active known_dir

  tmp_active="$(mktemp)"
  tmp_known="$(mktemp)"
  tmp_active_dirs="$(mktemp)"

  while IFS='|' read -r sess effective_ts created_ts; do
    [[ -n "$sess" ]] || continue
    # Fast path: rely on metadata captured when sessions are created/attached.
    # Avoid repeated registry/hash scans here; they can dominate picker startup.
    dir="$(session_meta_get_dir "$sess" 2>/dev/null || true)"
    if [[ -z "$dir" && "${WT_ZELLIJ_RESOLVE_ACTIVE_VIA_REGISTRY:-0}" == "1" ]]; then
      dir="$(dir_for_session "$sess" 2>/dev/null || true)"
    fi
    [[ -n "$dir" ]] && printf "%s\n" "$dir" >> "$tmp_active_dirs"
    printf "%s|%s|%s|1|%s\n" "$sess" "$effective_ts" "$created_ts" "${dir:-"(unknown)"}" >> "$tmp_active"
  done < <(list_sessions_raw)

  sort -u "$tmp_active_dirs" -o "$tmp_active_dirs" 2>/dev/null || true

  while IFS='|' read -r known_sess known_effective known_created known_is_active known_dir; do
    [[ -n "$known_dir" ]] || continue
    if [[ -s "$tmp_active_dirs" ]] && grep -Fxq "$known_dir" "$tmp_active_dirs"; then
      continue
    fi
    printf "%s|%s|%s|0|%s\n" "$known_sess" "$known_effective" "$known_created" "$known_dir" >> "$tmp_known"
  done < <(list_known_sessions_with_cached_age)

  cat "$tmp_active" "$tmp_known" | sort -t'|' -k2,2nr
  rm -f "$tmp_active" "$tmp_known" "$tmp_active_dirs"
}

list_sessions_pretty() {
  local sess effective_ts created_ts is_active dir dir_short dir_display agents agents_col attached_icon time_ago
  local attached_file
  local now_ts
  now_ts="$(date +%s)"
  maybe_refresh_age_cache_async
  attached_file="$(mktemp)"
  list_attached_sessions > "$attached_file" 2>/dev/null || true

  while IFS='|' read -r sess effective_ts created_ts is_active dir; do
    [[ -n "$sess" ]] || continue

    dir_short="$(short_path "${dir:-(unknown)}")"
    dir_display="$(collapse_dir_for_display "$dir_short")"

    if [[ "$is_active" == "1" ]]; then
      agents="$(session_meta_get_field "$sess" "agents" 2>/dev/null || true)"
      [[ -n "$agents" ]] || agents="(none)"
    else
      agents="(none)"
    fi
    agents_col="$(color_agents "$agents")"

    if [[ "$is_active" == "1" ]] && [[ -s "$attached_file" ]] && grep -Fxq "$sess" "$attached_file"; then
      attached_icon="${C_GREEN}●${C_RESET}"
    else
      attached_icon="${C_GRAY}○${C_RESET}"
    fi

    time_ago="${C_GRAY}$(relative_time "$effective_ts" "$now_ts")${C_RESET}"
    printf "%s\t%s\t%s\t%s\t%s\t%s\n" \
      "$sess" "$effective_ts" "$attached_icon" "$agents_col" "$dir_display" "$time_ago"
  done < <(list_sessions_combined_raw) \
    | sort -t$'\t' -k2,2nr
  rm -f "$attached_file"
}

preview_session() {
  local sess="$1"
  local agents dir tabs tmp
  local is_active=1

  if [[ -d "$sess" ]]; then
    dir="$sess"
    sess="$(sess_for_dir "$dir")"
  fi

  session_exists "$sess" || is_active=0
  if [[ "$is_active" == "1" ]]; then
    agents="$(session_agents "$sess")"
  else
    agents="$(session_meta_get_field "$sess" "agents" 2>/dev/null || true)"
    [[ -n "$agents" ]] || agents="(none)"
  fi
  dir="$(dir_for_session "$sess" 2>/dev/null || echo "(unknown)")"
  if [[ "$is_active" == "1" ]]; then
    tabs="$(session_tab_names "$sess" | paste -sd ', ' -)"
    [[ -z "$tabs" ]] && tabs="(none)"
  else
    tabs="(session not active - will be created on attach)"
  fi

  printf "\033[1;37m── %s ──\033[0m\n" "$sess"
  printf "agents: %s\n" "$agents"
  printf "dir:    %s\n" "$(short_path "$dir")"
  printf "tabs:   %s\n\n" "$tabs"

  [[ "$is_active" == "1" ]] || return 0

  tmp="$(mktemp)"
  if run_with_timeout 4 zellij --session "$sess" action dump-screen -f "$tmp" >/dev/null 2>&1; then
    tail -n 80 "$tmp"
  else
    echo "(no preview)"
  fi
  rm -f "$tmp"
}

ensure_agent_tab() {
  local sess="$1" wname="$2" dir="$3" cmd="$4"
  local launch_cmd
  local clients=0

  if ! session_has_tab "$sess" "$wname"; then
    run_with_timeout 4 zellij --session "$sess" action new-tab -n "$wname" -c "$dir" >/dev/null 2>&1 || true
    # If the previous call timed out or failed, try create-via-focus as fallback.
    if ! session_has_tab "$sess" "$wname"; then
      run_with_timeout 4 zellij --session "$sess" action go-to-tab-name --create "$wname" >/dev/null 2>&1 || true
    fi
    launch_cmd="cd \"$dir\" && ${cmd}; exec \"\$SHELL\" -l"
    # Launch command asynchronously so wt does not block on long-running agent startups.
    (run_with_timeout 6 zellij --session "$sess" run --cwd "$dir" --close-on-exit -- bash -lc "$launch_cmd" >/dev/null 2>&1 || true) &
  fi
  clients="$(session_client_count "$sess" 2>/dev/null || echo 0)"
  if [[ "$clients" =~ ^[0-9]+$ ]] && (( clients > 0 )); then
    run_with_timeout 2 zellij --session "$sess" action go-to-tab-name "$wname" >/dev/null 2>&1 || true
  fi
  session_meta_set_dir "$sess" "$dir"
  session_meta_set_field "$sess" "agents" "$(session_agents "$sess")"
  session_meta_mark_activity "$sess" "agent-tab"
}

attach_session() {
  local sess="$1"
  local create_if_missing="${2:-0}"
  session_meta_mark_activity "$sess" "attach"
  if [[ "${WT_NO_ATTACH:-0}" == "1" ]]; then
    return 0
  fi
  debug_log "attach_start sess=$sess zellij_var=${ZELLIJ:-} zellij_session=${ZELLIJ_SESSION_NAME:-} term=${TERM:-}"
  if inside_zellij; then
    debug_log "attach_skipped_inside sess=$sess"
    echo "Already inside a zellij session. Use the session UI to switch sessions." >&2
    echo "Tip: Ctrl+o then w (default keybind) opens session switcher." >&2
    return 0
  fi
  # fzf can occasionally leave terminal modes enabled (eg kitty keyboard protocol),
  # which breaks some zellij keybind handling until a manual reset.
  if [[ -r /dev/tty && -w /dev/tty ]]; then
    stty sane < /dev/tty 2>/dev/null || true
    printf '\033[?2004l\033[>4;0m' > /dev/tty 2>/dev/null || true
  fi
  if [[ "$create_if_missing" == "1" ]]; then
    debug_log "attach_exec sess=$sess create_if_missing=1"
    zellij attach -c "$sess"
  else
    debug_log "attach_exec sess=$sess create_if_missing=0"
    zellij attach "$sess"
  fi
}

kill_entry() {
  local entry="$1"
  local sess="$entry"
  local dir
  if [[ -d "$entry" ]]; then
    dir="$(canonpath "$entry")"
    sess="$(sess_for_dir "$dir")"
  fi
  [[ -n "$sess" ]] || return 0
  zellij kill-session "$sess" >/dev/null 2>&1 || true
  session_meta_remove "$sess"
}

rehydrate_sessions() {
  local mode="${1:-auto}"
  local dir sess created=0
  local use_full_scan=0

  if [[ "$mode" == "full" ]]; then
    use_full_scan=1
  elif ! registry_has_dirs && [[ "${WT_REHYDRATE_DISCOVER_FALLBACK:-1}" == "1" ]]; then
    use_full_scan=1
  fi

  if (( use_full_scan )); then
    while IFS= read -r dir; do
      [[ -n "$dir" ]] || continue
      registry_add_dir "$dir"
      sess="$(sess_for_dir "$dir")"
      if ! session_exists "$sess"; then
        if ensure_session "$sess" "$dir"; then
          ((created++))
        fi
      fi
    done < <(discover_worktree_dirs)
  else
    while IFS= read -r dir; do
      [[ -n "$dir" ]] || continue
      sess="$(sess_for_dir "$dir")"
      if ! session_exists "$sess"; then
        if ensure_session "$sess" "$dir"; then
          ((created++))
        fi
      fi
    done < <(registry_dirs)
  fi

  printf "%s\n" "$created"
}

rehydrate_if_needed() {
  [[ -n "$(list_sessions_raw)" ]] && return 0
  rehydrate_sessions "auto" >/dev/null 2>&1 || true
}

resolve_entry_dir() {
  local entry="$1"
  local dir
  if [[ -d "$entry" ]]; then
    dir="$(canonpath "$entry")"
  else
    dir="$(dir_for_session "$entry" 2>/dev/null || true)"
  fi
  [[ -n "$dir" && -d "$dir" ]] || return 1
  printf "%s\n" "$dir"
}

emit_pick_cd_action() {
  local dir="$1"
  [[ -n "$dir" && -d "$dir" ]] || return 1
  if [[ -n "${WT_PICK_ACTION_FILE:-}" ]]; then
    printf "cd\t%s\n" "$dir" > "$WT_PICK_ACTION_FILE"
  else
    printf "%s\n" "$dir"
  fi
}

pick_directory() {
  local line entry selection dir
  local self; self="$(realpath "$0" 2>/dev/null || echo "$0")"

  if [[ -z "$(list_sessions_combined_raw)" ]]; then
    echo "No wt folders found. Run 'wt here' in a repo, or run 'wt revive' (or 'wt revive full')." >&2
    return 0
  fi

  if command -v fzf >/dev/null 2>&1; then
    selection="$(list_sessions_pretty | fzf \
      --ansi \
      --height=100% \
      --delimiter=$'\t' \
      --with-nth=3,4,5,6 \
      --header=$'  \033[1mattached  agents           dir                          last active\033[0m\n  Enter: print selected directory path' \
      --prompt='❯ ' \
      --info-command='printf "%s/%s" "$FZF_POS" "$FZF_MATCH_COUNT"' \
      --preview="$self _preview {1}" \
      --preview-window='up:30%:wrap' \
      --expect=enter \
      --no-sort \
    )" || return 0

    line="$(printf "%s\n" "$selection" | sed -n '2p')"
    entry="$(printf "%s" "$line" | cut -f1)"
  else
    local -a entries
    local i=1
    while IFS= read -r row; do
      entries+=("$row")
      local agents dir_text time_ago
      agents="$(printf "%s" "$row" | cut -f4 | sed 's/\x1b\[[0-9;]*m//g')"
      dir_text="$(printf "%s" "$row" | cut -f5)"
      time_ago="$(printf "%s" "$row" | cut -f6 | sed 's/\x1b\[[0-9;]*m//g')"
      printf "  %2d) %-20s  %-30s  %s\n" "$i" "$agents" "$dir_text" "$time_ago" >&2
      (( i++ ))
    done < <(list_sessions_pretty)
    [[ ${#entries[@]} -eq 0 ]] && echo "No wt sessions." && return 0
    printf "Pick session [1-%d]: " "${#entries[@]}" >&2
    read -r choice
    [[ "$choice" =~ ^[0-9]+$ && "$choice" -ge 1 && "$choice" -le "${#entries[@]}" ]] || return 0
    entry="$(printf "%s" "${entries[$((choice-1))]}" | cut -f1)"
  fi

  [[ -n "$entry" ]] || return 0
  dir="$(resolve_entry_dir "$entry" 2>/dev/null || true)"
  [[ -n "$dir" ]] || {
    echo "Could not resolve directory for selection: $entry" >&2
    return 1
  }
  printf "%s\n" "$dir"
}

pick_and_attach() {
  local target_window="${1:-}"
  local line sess selection key="enter" dir
  local create_if_missing=0
  local self; self="$(realpath "$0" 2>/dev/null || echo "$0")"

  if [[ -z "$(list_sessions_combined_raw)" ]]; then
    echo "No wt folders found. Run 'wt here' in a repo, or run 'wt revive' (or 'wt revive full')." >&2
    return 0
  fi

  if command -v fzf >/dev/null 2>&1; then
    selection="$(list_sessions_pretty | fzf \
      --ansi \
      --height=100% \
      --delimiter=$'\t' \
      --with-nth=3,4,5,6 \
      --header=$'  \033[1mattached  agents           dir                          last active\033[0m\n  Enter: cd dir  Left: codex  Right: claude  Ctrl-g: attach  Ctrl-k: kill session' \
      --prompt='❯ ' \
      --info-command='printf "%s/%s" "$FZF_POS" "$FZF_MATCH_COUNT"' \
      --preview="$self _preview {1}" \
      --preview-window='up:30%:wrap' \
      --expect=enter,left,right,ctrl-g \
      --bind "ctrl-k:execute-silent($self _kill_entry {1})+reload($self _list)+clear-query+first" \
      --no-sort \
    )" || return 0

    key="$(printf "%s\n" "$selection" | sed -n '1p')"
    line="$(printf "%s\n" "$selection" | sed -n '2p')"
    case "$key" in
      left)  target_window="codex" ;;
      right) target_window="claude" ;;
    esac
    sess="$(printf "%s" "$line" | cut -f1)"
  else
    local -a sessions
    local i=1
    while IFS= read -r entry; do
      sessions+=("$entry")
      local agents dir_text time_ago
      agents="$(printf "%s" "$entry" | cut -f4 | sed 's/\x1b\[[0-9;]*m//g')"
      dir_text="$(printf "%s" "$entry" | cut -f5)"
      time_ago="$(printf "%s" "$entry" | cut -f6 | sed 's/\x1b\[[0-9;]*m//g')"
      printf "  %2d) %-20s  %-30s  %s\n" "$i" "$agents" "$dir_text" "$time_ago" >&2
      (( i++ ))
    done < <(list_sessions_pretty)
    [[ ${#sessions[@]} -eq 0 ]] && echo "No wt sessions." && return 0
    printf "Pick session [1-%d]: " "${#sessions[@]}" >&2
    read -r choice
    [[ "$choice" =~ ^[0-9]+$ && "$choice" -ge 1 && "$choice" -le "${#sessions[@]}" ]] || return 0
    sess="$(printf "%s" "${sessions[$((choice-1))]}" | cut -f1)"
  fi

  [[ -n "$sess" ]] || return 0
  if [[ "$key" == "enter" ]]; then
    dir="$(resolve_entry_dir "$sess" 2>/dev/null || true)"
    [[ -n "$dir" ]] || {
      echo "Could not resolve directory for selection: $sess" >&2
      return 1
    }
    debug_log "pick_cd_selected selected=$sess dir=$dir"
    emit_pick_cd_action "$dir"
    return 0
  fi
  debug_log "pick_selected key=${key:-enter} target=${target_window:-default} selected=$sess zellij_var=${ZELLIJ:-} zellij_session=${ZELLIJ_SESSION_NAME:-}"
  if [[ -d "$sess" ]]; then
    dir="$(canonpath "$sess")"
    sess="$(sess_for_dir "$dir")"
    session_meta_set_dir "$sess" "$dir"
    create_if_missing=1
  fi
  # Fast path: default attach should avoid extra zellij action queries because they can
  # each block for multiple seconds when zellij is unhealthy.
  if [[ -z "$target_window" ]]; then
    attach_session "$sess" "$create_if_missing"
    return 0
  fi
  dir="${dir:-$(dir_for_session "$sess" 2>/dev/null || printf "%s" "$PWD")}"
  ensure_session "$sess" "$dir" || return 1
  if [[ -n "$target_window" ]]; then
    if [[ "$target_window" == "codex" ]]; then
      ensure_agent_tab "$sess" "codex" "$dir" "codex --yolo resume"
    elif [[ "$target_window" == "claude" ]]; then
      ensure_agent_tab "$sess" "claude" "$dir" "claude --dangerously-skip-permissions --continue"
    fi
  fi

  attach_session "$sess"
}

main() {
  require_zellij
  local cmd="${1:-here}"
  local dir sess

  case "$cmd" in
    here)
      dir="$(canonpath "$PWD")"
      sess="$(sess_for_dir "$dir")"
      ensure_session "$sess" "$dir" || return 1
      if [[ -z "$(session_meta_get_field "$sess" "agents" 2>/dev/null || true)" ]]; then
        session_meta_set_field "$sess" "agents" "(none)"
      fi
      attach_session "$sess"
      ;;

    codex)
      dir="$(canonpath "$PWD")"
      sess="$(sess_for_dir "$dir")"
      ensure_session "$sess" "$dir" || return 1
      ensure_agent_tab "$sess" "codex" "$dir" "codex --yolo resume"
      attach_session "$sess"
      ;;

    claude)
      dir="$(canonpath "$PWD")"
      sess="$(sess_for_dir "$dir")"
      ensure_session "$sess" "$dir" || return 1
      ensure_agent_tab "$sess" "claude" "$dir" "claude --dangerously-skip-permissions --continue"
      attach_session "$sess"
      ;;

    pick)
      pick_and_attach "${2:-}"
      ;;

    pickdir|cd)
      pick_directory
      ;;

    revive)
      created="$(rehydrate_sessions "${2:-auto}")"
      echo "Rehydrated ${created} session(s)."
      ;;

    _list)
      list_sessions_pretty
      ;;

    _refresh_age_cache)
      refresh_age_cache
      ;;

    _refresh_discovery_cache)
      refresh_discovery_cache
      ;;

    _preview)
      sess="${2:-}"
      [[ -z "$sess" ]] && exit 0
      preview_session "$sess"
      ;;

    _kill_entry)
      sess="${2:-}"
      [[ -z "$sess" ]] && exit 0
      kill_entry "$sess"
      ;;

    ls)
      list_sessions_pretty \
        | awk -F'\t' '{printf "%-30s  %s  %-20s  %-30s  %s\n", $1, $3, $4, $5, $6}' \
        | sed 's/\x1b\[[0-9;]*m//g'
      ;;

    kill)
      dir="$(canonpath "$PWD")"
      sess="$(sess_for_dir "$dir")"
      if ! session_exists "$sess"; then
        sess="$(find_active_session_for_dir "$dir" 2>/dev/null || true)"
      fi
      if ! session_exists "$sess"; then
        echo "No zellij wt session found for: $(short_path "$dir")" >&2
        return 0
      fi
      zellij kill-session "$sess"
      session_meta_remove "$sess"
      echo "Killed session: $sess"
      ;;

    *)
      cat <<'EOF'
Usage: wt [subcommand]

  here      Create/attach zellij session for current directory (default)
  codex     Ensure a "codex" tab exists (runs `codex --yolo resume` on first use)
  claude    Ensure a "claude" tab exists (runs `claude --dangerously-skip-permissions --continue` on first use)
  pick      Fuzzy-pick from all known wt folders (active + dormant) and attach (optionally pass `codex` or `claude` to focus that tab)
              in picker: Enter=cd directory, Left=codex, Right=claude, Ctrl-g=default attach
              Enter cd requires wt.sh wrapper for in-shell cd
              ctrl-k  kill selected session and reload list
  pickdir   Fuzzy-pick and print the selected directory path (does not attach/start zellij)
  cd        Alias for `pickdir` (intended for shell wrapper functions that run `cd`)
  revive    Recreate missing wt sessions
              default: restore from $WT_REGISTRY_FILE (dirs you've used with wt)
              full:    run `wt revive full` to scan discovery roots
              discovery roots: ~/Downloads/worktrees, ~/.codex/worktrees, ~/.openclaw/workspace, $PWD
              customize discovery roots via WT_DISCOVER_ROOTS (colon-separated absolute paths)
  ls        List all wt sessions with agent tabs and directories
  kill      Kill the zellij session for current directory
EOF
      exit 1
      ;;
  esac
}

main "$@"
