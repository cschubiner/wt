#!/usr/bin/env bash
# wt — persistent workspace manager for git worktrees
# Usage: wt [here|codex|claude|pick|pickdir|cd|revive|ls|kill]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Backend selection.
# Defaults to zellij; set WT_BACKEND=tmux for legacy behavior.
case "${WT_BACKEND:-zellij}" in
  zellij)
    exec "$SCRIPT_DIR/wt-zellij" "$@"
    ;;
  tmux)
    ;;
  *)
    echo "Unknown WT_BACKEND='${WT_BACKEND}'. Use 'zellij' or 'tmux'." >&2
    exit 1
    ;;
esac

# ---- ANSI colors ----
C_RESET=$'\033[0m'
C_GREEN=$'\033[1;32m'
C_YELLOW=$'\033[1;33m'
C_CYAN=$'\033[1;36m'
C_BLUE=$'\033[1;34m'
C_GRAY=$'\033[0;90m'
C_RED=$'\033[1;31m'

# Registry of known wt directories so post-reboot rehydrate can restore
# the sessions you actually use (instead of scanning broad filesystem roots).
WT_REGISTRY_FILE="${WT_REGISTRY_FILE:-$HOME/.wt_registry}"

# ---- helpers ----

canonpath() {
  if command -v realpath >/dev/null 2>&1; then
    realpath "$1"
  else
    python3 - "$1" <<'PY'
import os, sys; print(os.path.realpath(sys.argv[1]))
PY
  fi
}

hash6() {
  local s="$1"
  if command -v sha1sum >/dev/null 2>&1; then
    printf "%s" "$s" | sha1sum | awk '{print substr($1,1,6)}'
  elif command -v shasum >/dev/null 2>&1; then
    printf "%s" "$s" | shasum | awk '{print substr($1,1,6)}'
  else
    python3 - "$s" <<'PY'
import hashlib, sys; print(hashlib.sha1(sys.argv[1].encode()).hexdigest()[:6])
PY
  fi
}

sess_for_dir() {
  local dir="$1"
  local base
  base="$(basename "$dir" | tr -cs 'A-Za-z0-9' '_' | sed 's/_*$//' | cut -c1-24)"
  local h
  h="$(hash6 "$dir")"
  echo "wt_${base}_${h}"
}

inside_tmux() {
  [[ -n "${TMUX:-}" ]]
}

short_path() {
  # Replace $HOME prefix with ~
  printf "%s" "${1/#$HOME/~}"
}

registry_add_dir() {
  local dir="${1:-}"
  [[ -n "$dir" && -d "$dir" ]] || return 0
  dir="$(canonpath "$dir")"

  mkdir -p "$(dirname "$WT_REGISTRY_FILE")"
  touch "$WT_REGISTRY_FILE"
  grep -Fxq "$dir" "$WT_REGISTRY_FILE" 2>/dev/null || printf "%s\n" "$dir" >> "$WT_REGISTRY_FILE"
}

registry_has_dirs() {
  local d
  [[ -f "$WT_REGISTRY_FILE" ]] || return 1
  while IFS= read -r d; do
    [[ -d "$d" ]] && return 0
  done < "$WT_REGISTRY_FILE"
  return 1
}

registry_dirs() {
  local d
  [[ -f "$WT_REGISTRY_FILE" ]] || return 0
  while IFS= read -r d; do
    [[ -d "$d" ]] && printf "%s\n" "$d"
  done < "$WT_REGISTRY_FILE"
}

tmux_server_running() {
  tmux list-sessions >/dev/null 2>&1
}

discover_roots() {
  local -a roots
  local root
  if [[ -n "${WT_DISCOVER_ROOTS:-}" ]]; then
    IFS=':' read -r -a roots <<<"${WT_DISCOVER_ROOTS}"
    for root in "${roots[@]}"; do
      [[ -n "$root" ]] && printf "%s\n" "$root"
    done
    return 0
  fi

  printf "%s\n" \
    "$HOME/Downloads/worktrees" \
    "$HOME/.codex/worktrees" \
    "$HOME/.openclaw/workspace" \
    "$PWD"
}

discover_worktree_dirs() {
  local root expanded gitfile dir
  while IFS= read -r root; do
    [[ -n "$root" ]] || continue
    if [[ "$root" == "~"* ]]; then
      expanded="${HOME}${root:1}"
    else
      expanded="$root"
    fi
    [[ -d "$expanded" ]] || continue

    if git -C "$expanded" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      canonpath "$expanded"
    fi

    while IFS= read -r gitfile; do
      dir="$(dirname "$gitfile")"
      git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || continue
      canonpath "$dir"
    done < <(find "$expanded" -maxdepth 4 -type f -name .git 2>/dev/null)
  done < <(discover_roots) | awk 'NF && !seen[$0]++'
}

rehydrate_sessions() {
  # Modes:
  #   auto (default): registry first; fallback to discovery if registry is empty
  #   full:           force discovery roots scan
  local mode="${1:-auto}"
  local dir sess created=0
  local use_full_scan=0

  if [[ "$mode" == "full" ]]; then
    use_full_scan=1
  elif ! registry_has_dirs && [[ "${WT_REHYDRATE_DISCOVER_FALLBACK:-1}" == "1" ]]; then
    use_full_scan=1
  fi

  if (( use_full_scan )); then
    while IFS= read -r dir; do
      [[ -n "$dir" ]] || continue
      registry_add_dir "$dir"
      sess="$(sess_for_dir "$dir")"
      if ! tmux has-session -t "$sess" 2>/dev/null; then
        ensure_session "$sess" "$dir"
        ((created++))
      fi
    done < <(discover_worktree_dirs)
  else
    while IFS= read -r dir; do
      [[ -n "$dir" ]] || continue
      sess="$(sess_for_dir "$dir")"
      if ! tmux has-session -t "$sess" 2>/dev/null; then
        ensure_session "$sess" "$dir"
        ((created++))
      fi
    done < <(registry_dirs)
  fi

  printf "%s\n" "$created"
}

mark_session_known() {
  local sess="$1" dir=""
  [[ -n "$sess" ]] || return 0
  dir="$(dir_for_session "$sess" 2>/dev/null || true)"
  [[ -z "$dir" ]] && dir="$(tmux show-environment -t "$sess" WT_DIR 2>/dev/null | sed -n 's/^WT_DIR=//p' || true)"
  [[ -n "$dir" ]] && registry_add_dir "$dir"
}

dir_for_session() {
  local sess="$1" dir=""
  [[ -n "$sess" ]] || return 1
  dir="$(tmux display-message -p -t "$sess" '#{@wt_dir}' 2>/dev/null || true)"
  [[ -z "$dir" ]] && dir="$(tmux display-message -p -t "$sess" '#{session_path}' 2>/dev/null || true)"
  [[ -n "$dir" && -d "$dir" ]] || return 1
  canonpath "$dir"
}

emit_pick_cd_action() {
  local dir="$1"
  [[ -n "$dir" && -d "$dir" ]] || return 1
  if [[ -n "${WT_PICK_ACTION_FILE:-}" ]]; then
    printf "cd\t%s\n" "$dir" > "$WT_PICK_ACTION_FILE"
  else
    printf "%s\n" "$dir"
  fi
}

rehydrate_if_needed() {
  local raw
  raw="$(list_sessions_raw)"
  [[ -n "$raw" ]] && return 0

  # Only auto-rehydrate when tmux server is absent (e.g. post-reboot).
  # If tmux is running but there are no wt sessions, avoid surprise full scans.
  if ! tmux_server_running; then
    rehydrate_sessions "auto" >/dev/null 2>&1 || true
  fi
}

collapse_dir_for_display() {
  local dir="$1"
  case "$dir" in
    \~/Downloads/worktrees/*)
      printf ".../%s" "${dir#\~/Downloads/worktrees/}"
      ;;
    \~/.codex/worktrees/*)
      printf ".../%s" "${dir#\~/.codex/worktrees/}"
      ;;
    \~/.openclaw/workspace/*)
      printf ".../%s" "${dir#\~/.openclaw/workspace/}"
      ;;
    *)
      printf "%s" "$dir"
      ;;
  esac
}

relative_time() {
  # Convert a unix timestamp to "Xm ago", "Xh ago", "Xd ago"
  local ts="$1"
  local now="${2:-}"
  local delta
  [[ -z "$now" ]] && now="$(date +%s)"
  delta=$(( now - ts ))
  if   (( delta < 60   )); then printf "%ds ago" "$delta"
  elif (( delta < 3600 )); then printf "%dm ago" "$(( delta / 60 ))"
  elif (( delta < 86400)); then printf "%dh ago" "$(( delta / 3600 ))"
  else                          printf "%dd ago" "$(( delta / 86400 ))"
  fi
}

file_mtime() {
  local p="$1" ts=""
  [[ -n "$p" && -e "$p" ]] || return 1
  if stat -f '%m' "$p" >/dev/null 2>&1; then
    ts="$(stat -f '%m' "$p" 2>/dev/null || true)"
  elif stat -c '%Y' "$p" >/dev/null 2>&1; then
    ts="$(stat -c '%Y' "$p" 2>/dev/null || true)"
  fi
  [[ "$ts" =~ ^[0-9]+$ ]] || return 1
  printf "%s" "$ts"
}

git_head_mtime() {
  local dir="$1" gitdir=""
  [[ -n "$dir" && -d "$dir" ]] || return 1

  if [[ -d "$dir/.git" ]]; then
    gitdir="$dir/.git"
  elif [[ -f "$dir/.git" ]]; then
    gitdir="$(sed -n 's/^gitdir: //p' "$dir/.git" | head -n 1)"
    [[ -n "$gitdir" ]] || return 1
    [[ "$gitdir" == /* ]] || gitdir="$dir/$gitdir"
  else
    return 1
  fi

  file_mtime "$gitdir/HEAD"
}

dir_activity_ts() {
  # Best-effort historical activity for dormant sessions restored after reboot.
  # Use git HEAD mtime (fast) then directory mtime, then fallback.
  local dir="$1" fallback_ts="$2"
  local ts=""

  if [[ -n "$dir" && -d "$dir" ]]; then
    ts="$(git_head_mtime "$dir" 2>/dev/null || true)"
    if [[ "$ts" =~ ^[0-9]+$ ]]; then
      printf "%s" "$ts"
      return 0
    fi

    ts="$(file_mtime "$dir" 2>/dev/null || true)"
    if [[ "$ts" =~ ^[0-9]+$ ]]; then
      printf "%s" "$ts"
      return 0
    fi
  fi

  printf "%s" "$fallback_ts"
}

color_agents() {
  # Colorize the agents string: codex=yellow, claude=cyan, both=green
  local agents="$1"
  case "$agents" in
    *codex*,*claude*|*claude*,*codex*)
      printf "${C_GREEN}%s${C_RESET}" "$agents" ;;
    *codex*)
      printf "${C_YELLOW}%s${C_RESET}" "$agents" ;;
    *claude*)
      printf "${C_CYAN}%s${C_RESET}" "$agents" ;;
    *)
      printf "${C_GRAY}%s${C_RESET}" "$agents" ;;
  esac
}

ensure_session() {
  local sess="$1" dir="$2"
  registry_add_dir "$dir"
  if ! tmux has-session -t "$sess" 2>/dev/null; then
    tmux new-session -d -s "$sess" -c "$dir" -n shell
  fi
  tmux set-environment -t "$sess" WT_DIR "$dir" || true
  tmux set-option -t "$sess" -q @wt_dir "$dir" || true
}

window_exists() {
  local sess="$1" wname="$2"
  tmux list-windows -t "$sess" -F '#{window_name}' 2>/dev/null | grep -Fxq "$wname"
}

ensure_window() {
  local sess="$1" wname="$2" dir="$3" cmd="$4"
  if ! window_exists "$sess" "$wname"; then
    # Run the agent command once on first creation; leave a live shell when it exits.
    tmux new-window -t "$sess" -n "$wname" -c "$dir" \
      "bash -lc '${cmd}; exec \"\$SHELL\" -l'"
  fi
}

focus_window() {
  local sess="$1" wname="$2"
  tmux select-window -t "${sess}:${wname}" 2>/dev/null || true
}

attach_or_switch() {
  local sess="$1"
  if inside_tmux; then
    tmux switch-client -t "$sess"
  else
    # No -d: allows multiple devices to attach simultaneously.
    tmux attach -t "$sess"
  fi
}

# Output format (tab-separated, sorted by activity desc):
#   session_name \t activity_ts \t attached \t agents_colored \t short_dir \t time_ago
list_sessions_raw() {
  # Use | as delimiter (safe: tmux session names cannot contain |)
  tmux list-sessions \
    -F '#{session_name}|#{session_activity}|#{session_attached}|#{@wt_dir}|#{@wt_dormant_ts}|#{session_path}' \
    2>/dev/null \
    | awk -F'|' '$1 ~ /^wt_/ { print }' \
    | sort -t'|' -k2 -rn \
    || true  # no tmux server/sessions after reboot is normal
}

list_sessions_pretty() {
  local s ts attached dir_opt dormant_opt sess_path dir agents attached_icon agents_col time_ago dir_short effective_ts
  local wins_blob cached_dormant_ts
  local now_ts
  local -a sesses tss attached_icons agents_cols dirs_shorts time_agos
  now_ts="$(date +%s)"
  wins_blob=$'\n'"$(tmux list-windows -a -F '#{session_name}|#{window_name}' 2>/dev/null || true)"$'\n'

  while IFS='|' read -r s ts attached dir_opt dormant_opt sess_path; do
    dir="$dir_opt"
    [[ -z "$dir" ]] && dir="$sess_path"
    [[ -z "$dir" ]] && dir="$(tmux show-environment -t "$s" WT_DIR 2>/dev/null | sed -n 's/^WT_DIR=//p' || true)"

    # agents
    agents=""
    [[ "$wins_blob" == *$'\n'"$s|codex"$'\n'* ]] && agents="${agents}codex,"
    [[ "$wins_blob" == *$'\n'"$s|claude"$'\n'* ]] && agents="${agents}claude,"
    agents="${agents%,}"
    agents="${agents:-(none)}"

    # attached indicator
    if [[ "$attached" -gt 0 ]]; then
      attached_icon="${C_GREEN}●${C_RESET}"
    else
      attached_icon="${C_GRAY}○${C_RESET}"
    fi

    effective_ts="$ts"
    # After reboot+revive, dormant "(none)" sessions all look "just now" if we use tmux activity.
    # Show repo age instead until the session is actively used again.
    if [[ "$agents" == "(none)" && "$attached" -eq 0 ]]; then
      cached_dormant_ts="$dormant_opt"
      if [[ "$cached_dormant_ts" =~ ^[0-9]+$ ]]; then
        effective_ts="$cached_dormant_ts"
      else
        effective_ts="$(dir_activity_ts "$dir" "$ts")"
        tmux set-option -t "$s" -q @wt_dormant_ts "$effective_ts" >/dev/null 2>&1 || true
      fi
    fi

    agents_col="$(color_agents "$agents")"
    time_ago="${C_GRAY}$(relative_time "$effective_ts" "$now_ts")${C_RESET}"
    dir_short="$(short_path "${dir:-(unknown)}")"

    sesses+=("$s")
    tss+=("$effective_ts")
    attached_icons+=("$attached_icon")
    agents_cols+=("$agents_col")
    dirs_shorts+=("$dir_short")
    time_agos+=("$time_ago")
  done < <(list_sessions_raw)

  local i n
  local dir_display
  n="${#sesses[@]}"
  {
    for (( i=0; i<n; i++ )); do
      dir_display="$(collapse_dir_for_display "${dirs_shorts[i]}")"

      # cols: session_name \t ts(hidden) \t attached \t agents \t dir \t time_ago
      printf "%s\t%s\t%s\t%s\t%s\t%s\n" \
        "${sesses[i]}" "${tss[i]}" "${attached_icons[i]}" "${agents_cols[i]}" "$dir_display" "${time_agos[i]}"
    done
  } | sort -t$'\t' -k2,2nr
  return 0
}

# Preview script: capture the most relevant window for a session
preview_session() {
  local sess="$1"
  # Prefer claude > codex > first window
  local win
  if tmux list-windows -t "$sess" -F '#{window_name}' 2>/dev/null | grep -Fxq claude; then
    win="claude"
  elif tmux list-windows -t "$sess" -F '#{window_name}' 2>/dev/null | grep -Fxq codex; then
    win="codex"
  else
    win="shell"
  fi
  printf "\033[1;37m── %s:%s ──\033[0m\n" "$sess" "$win"
  tmux capture-pane -p -t "${sess}:${win}" -e 2>/dev/null || echo "(no output)"
}
pick_and_attach() {
  local target_window="${1:-}"
  local line sess selection key="enter"
  local self; self="$(realpath "$0" 2>/dev/null || echo "$0")"

  rehydrate_if_needed

  if [[ -z "$(list_sessions_raw)" ]]; then
    echo "No wt sessions found. Run 'wt here' in a repo, or run 'wt revive' (or 'wt revive full')." >&2
    return 0
  fi

  if command -v fzf >/dev/null 2>&1; then
    selection="$(list_sessions_pretty | fzf \
      --ansi \
      --height=100% \
      --delimiter=$'\t' \
      --with-nth=3,4,5,6 \
      --header=$'  \033[1mattached  agents           dir                          last active\033[0m\n  Enter: cd dir  Left: codex  Right: claude  Ctrl-g: attach  Ctrl-k: kill session' \
      --prompt='❯ ' \
      --info-command='printf "%s/%s" "$FZF_POS" "$FZF_MATCH_COUNT"' \
      --preview="$self _preview {1}" \
      --preview-window='up:30%:wrap' \
      --expect=enter,left,right,ctrl-g \
      --bind "ctrl-k:execute-silent(tmux kill-session -t {1})+reload($self _list)+clear-query+first" \
      --no-sort \
    )" || return 0
    key="$(printf "%s\n" "$selection" | sed -n '1p')"
    line="$(printf "%s\n" "$selection" | sed -n '2p')"

    case "$key" in
      left)  target_window="codex" ;;
      right) target_window="claude" ;;
    esac

    sess="$(printf "%s" "$line" | cut -f1)"
  else
    # Fallback: numbered select when fzf is not installed
    local -a sessions
    local i=1
    while IFS= read -r entry; do
      sessions+=("$entry")
      local agents dir time_ago
      agents="$(printf "%s" "$entry" | cut -f4 | sed 's/\x1b\[[0-9;]*m//g')"
      dir="$(printf "%s" "$entry" | cut -f5)"
      time_ago="$(printf "%s" "$entry" | cut -f6 | sed 's/\x1b\[[0-9;]*m//g')"
      printf "  %2d) %-20s  %-30s  %s\n" "$i" "$agents" "$dir" "$time_ago" >&2
      (( i++ ))
    done < <(list_sessions_pretty)
    [[ ${#sessions[@]} -eq 0 ]] && echo "No wt sessions." && return 0
    printf "Pick session [1-%d]: " "${#sessions[@]}" >&2
    read -r choice
    [[ "$choice" =~ ^[0-9]+$ && "$choice" -ge 1 && "$choice" -le "${#sessions[@]}" ]] || return 0
    sess="$(printf "%s" "${sessions[$((choice-1))]}" | cut -f1)"
  fi

  [[ -n "$sess" ]] || return 0
  if [[ "$key" == "enter" ]]; then
    local dir
    dir="$(dir_for_session "$sess" 2>/dev/null || true)"
    [[ -n "$dir" ]] || {
      echo "Could not resolve directory for selection: $sess" >&2
      return 1
    }
    emit_pick_cd_action "$dir"
    return 0
  fi
  mark_session_known "$sess"
  attach_or_switch "$sess"
  if [[ -n "$target_window" ]] && window_exists "$sess" "$target_window"; then
    focus_window "$sess" "$target_window"
  fi
}

pick_directory() {
  local line sess selection dir
  local self; self="$(realpath "$0" 2>/dev/null || echo "$0")"

  rehydrate_if_needed

  if [[ -z "$(list_sessions_raw)" ]]; then
    echo "No wt sessions found. Run 'wt here' in a repo, or run 'wt revive' (or 'wt revive full')." >&2
    return 0
  fi

  if command -v fzf >/dev/null 2>&1; then
    selection="$(list_sessions_pretty | fzf \
      --ansi \
      --height=100% \
      --delimiter=$'\t' \
      --with-nth=3,4,5,6 \
      --header=$'  \033[1mattached  agents           dir                          last active\033[0m\n  Enter: print selected directory path' \
      --prompt='❯ ' \
      --info-command='printf "%s/%s" "$FZF_POS" "$FZF_MATCH_COUNT"' \
      --preview="$self _preview {1}" \
      --preview-window='up:30%:wrap' \
      --expect=enter \
      --no-sort \
    )" || return 0
    line="$(printf "%s\n" "$selection" | sed -n '2p')"
    sess="$(printf "%s" "$line" | cut -f1)"
  else
    local -a sessions
    local i=1
    while IFS= read -r entry; do
      sessions+=("$entry")
      local agents dir_text time_ago
      agents="$(printf "%s" "$entry" | cut -f4 | sed 's/\x1b\[[0-9;]*m//g')"
      dir_text="$(printf "%s" "$entry" | cut -f5)"
      time_ago="$(printf "%s" "$entry" | cut -f6 | sed 's/\x1b\[[0-9;]*m//g')"
      printf "  %2d) %-20s  %-30s  %s\n" "$i" "$agents" "$dir_text" "$time_ago" >&2
      (( i++ ))
    done < <(list_sessions_pretty)
    [[ ${#sessions[@]} -eq 0 ]] && echo "No wt sessions." && return 0
    printf "Pick session [1-%d]: " "${#sessions[@]}" >&2
    read -r choice
    [[ "$choice" =~ ^[0-9]+$ && "$choice" -ge 1 && "$choice" -le "${#sessions[@]}" ]] || return 0
    sess="$(printf "%s" "${sessions[$((choice-1))]}" | cut -f1)"
  fi

  [[ -n "$sess" ]] || return 0
  dir="$(dir_for_session "$sess" 2>/dev/null || true)"
  [[ -n "$dir" && -d "$dir" ]] || {
    echo "Could not resolve directory for selection: $sess" >&2
    return 1
  }
  printf "%s\n" "$dir"
}

# ---- main ----

cmd="${1:-here}"

case "$cmd" in
  here)
    dir="$(canonpath "${PWD}")"
    sess="$(sess_for_dir "$dir")"
    ensure_session "$sess" "$dir"
    attach_or_switch "$sess"
    ;;

  codex)
    dir="$(canonpath "${PWD}")"
    sess="$(sess_for_dir "$dir")"
    ensure_session "$sess" "$dir"
    ensure_window  "$sess" "codex" "$dir" "cd \"$dir\" && codex --yolo resume"
    attach_or_switch "$sess"
    focus_window "$sess" "codex"
    ;;

  claude)
    dir="$(canonpath "${PWD}")"
    sess="$(sess_for_dir "$dir")"
    ensure_session "$sess" "$dir"
    ensure_window  "$sess" "claude" "$dir" "cd \"$dir\" && claude --dangerously-skip-permissions --continue"
    attach_or_switch "$sess"
    focus_window "$sess" "claude"
    ;;

  pick)
    pick_and_attach "${2:-}"
    ;;

  pickdir|cd)
    pick_directory
    ;;

  revive)
    created="$(rehydrate_sessions "${2:-auto}")"
    echo "Rehydrated ${created} session(s)."
    ;;

  # Internal subcommands used by fzf --preview and --bind reload
  _list)
    list_sessions_pretty
    ;;

  _preview)
    sess="${2:-}"
    [[ -z "$sess" ]] && exit 0
    # Prefer claude > codex > shell window for preview
    if tmux list-windows -t "$sess" -F '#{window_name}' 2>/dev/null | grep -Fxq claude; then
      win=claude
    elif tmux list-windows -t "$sess" -F '#{window_name}' 2>/dev/null | grep -Fxq codex; then
      win=codex
    else
      win=shell
    fi
    printf "\033[1;37m── %s : %s ──\033[0m\n" "$sess" "$win"
    tmux capture-pane -p -t "${sess}:${win}" -e 2>/dev/null || echo "(no output)"
    ;;

  ls)
    list_sessions_pretty \
      | awk -F'\t' '{printf "%-30s  %s  %-20s  %-30s  %s\n", $1, $3, $4, $5, $6}' \
      | sed 's/\x1b\[[0-9;]*m//g'
    ;;

  kill)
    dir="$(canonpath "${PWD}")"
    sess="$(sess_for_dir "$dir")"
    tmux kill-session -t "$sess"
    echo "Killed session: $sess"
    ;;

  *)
    cat <<'EOF'
Usage: wt [subcommand]

  here      Create/attach tmux session for current directory (default)
  codex     Ensure a "codex" window exists (runs `codex --yolo resume` on first use)
  claude    Ensure a "claude" window exists (runs `claude --dangerously-skip-permissions --continue` on first use)
  pick      Fuzzy-pick from all active wt sessions and attach (optionally pass `codex` or `claude` to focus that window)
              in picker: Enter=cd directory, Left=codex, Right=claude, Ctrl-g=default attach
              Enter cd requires wt.sh wrapper for in-shell cd
              ctrl-k  kill selected session and reload list
  pickdir   Fuzzy-pick and print the selected directory path (does not attach/start tmux)
  cd        Alias for `pickdir` (intended for shell wrapper functions that run `cd`)
  revive    Recreate missing wt sessions
              default: restore from $WT_REGISTRY_FILE (dirs you've used with wt)
              full:    run `wt revive full` to scan discovery roots
              discovery roots: ~/Downloads/worktrees, ~/.codex/worktrees, ~/.openclaw/workspace, \$PWD
              customize discovery roots via WT_DISCOVER_ROOTS (colon-separated absolute paths)
  ls        List all wt sessions with agent windows and directories
  kill      Kill the tmux session for current directory

Each worktree gets its own persistent tmux session. Sessions survive terminal
closes/crashes. Attach from any device via SSH: wt pick
